# Required — get one at https://console.groq.com/keys
GROQ_API_KEY=

# Comma-separated list of origins allowed to call the backend.
# Local/docker-compose default (matches backend/main.py's fallback) — leave
# unset for local dev. In production, set this to your deployed frontend's
# origin(s), e.g.:
#   ALLOWED_ORIGINS=https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://frontend:3000
